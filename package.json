{
  "name": "rm-connector-js",
  "description": "IBM i DB2 connector for Node.js — supports mapepire (remote) and idb-pconnector (native) backends",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "prepare": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "DB2",
    "DB2 for i",
    "DB2 for IBM i",
    "DB2 client",
    "RPG",
    "SQL",
    "CL",
    "COBOL",
    "IBMi",
    "IBM",
    "IBM i"
  ],
  "author": "Richard Moulton",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richardm90/rm-connector-js.git"
  },
  "bugs": {
    "url": "https://github.com/richardm90/rm-connector-js/issues"
  },
  "homepage": "https://github.com/richardm90/rm-connector-js#readme",
  "dependencies": {
    "@ibm/mapepire-js": "^0.6.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.4",
    "typescript": "^5.9.3"
  }
}
